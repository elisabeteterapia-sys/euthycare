# ─── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ─── App ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://euthycare.pt

# ─── Admin ────────────────────────────────────────────────────
ADMIN_SECRET=change-me-before-deploy

# ─── Storage ──────────────────────────────────────────────────
STORAGE_BUCKET=uploads
# Private bucket for digital product files (PDFs) — must be PRIVATE
STORAGE_BUCKET_PRODUTOS=produtos-pdf

# ─── Loja (digital products) ──────────────────────────────────
# Webhook secret for the store's Stripe endpoint (/loja/webhook/stripe)
STRIPE_LOJA_WEBHOOK_SECRET=whsec_...

# ─── Stripe (primary gateway) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Trial period for new subscriptions (days)
# Set to 0 to disable trial
TRIAL_DAYS=30

# ─── Stripe Price IDs per plan × interval × currency ──────────
# Preferred: set these in the public.plans table (stripe_price_* columns).
# These env vars serve as fallback only.

# Essencial — €19/mês | €190/ano
STRIPE_PRICE_ESSENCIAL_MONTH_EUR=price_...
STRIPE_PRICE_ESSENCIAL_MONTH_USD=price_...
STRIPE_PRICE_ESSENCIAL_MONTH_BRL=price_...
STRIPE_PRICE_ESSENCIAL_YEAR_EUR=price_...
STRIPE_PRICE_ESSENCIAL_YEAR_USD=price_...
STRIPE_PRICE_ESSENCIAL_YEAR_BRL=price_...

# Profissional — €39/mês | €390/ano
STRIPE_PRICE_PROFISSIONAL_MONTH_EUR=price_...
STRIPE_PRICE_PROFISSIONAL_MONTH_USD=price_...
STRIPE_PRICE_PROFISSIONAL_MONTH_BRL=price_...
STRIPE_PRICE_PROFISSIONAL_YEAR_EUR=price_...
STRIPE_PRICE_PROFISSIONAL_YEAR_USD=price_...
STRIPE_PRICE_PROFISSIONAL_YEAR_BRL=price_...

# Premium — €69/mês | €690/ano
STRIPE_PRICE_PREMIUM_MONTH_EUR=price_...
STRIPE_PRICE_PREMIUM_MONTH_USD=price_...
STRIPE_PRICE_PREMIUM_MONTH_BRL=price_...
STRIPE_PRICE_PREMIUM_YEAR_EUR=price_...
STRIPE_PRICE_PREMIUM_YEAR_USD=price_...
STRIPE_PRICE_PREMIUM_YEAR_BRL=price_...

# Clínica — €149/mês | €1490/ano
STRIPE_PRICE_CLINICA_MONTH_EUR=price_...
STRIPE_PRICE_CLINICA_MONTH_USD=price_...
STRIPE_PRICE_CLINICA_MONTH_BRL=price_...
STRIPE_PRICE_CLINICA_YEAR_EUR=price_...
STRIPE_PRICE_CLINICA_YEAR_USD=price_...
STRIPE_PRICE_CLINICA_YEAR_BRL=price_...

# ─── Future local payment methods (disabled by default) ────────
# Set to 'true' to activate. Implementation stubs are in
# backend/src/lib/payments/mbway-provider.ts and multibanco-provider.ts

ENABLE_MBWAY=false
MBWAY_API_KEY=
MBWAY_ENTITY_KEY=
MBWAY_WEBHOOK_SECRET=

ENABLE_MULTIBANCO=false
MULTIBANCO_ENTITY=
MULTIBANCO_API_KEY=
